@page "/projects"

<PageTitle>Projects</PageTitle>

<section class="py-5 min-vh-100" style="background-color: #002147">
    <div class="container">

        <!-- Heading -->
        <div class="text-center mb-5">
            <span class="badge fs-6 px-3 py-2 text-bg-primary text-light">
                Portfolio Projects
            </span>

            <h1 class="display-4 fw-bold mt-3 text-danger">
                My Projects
            </h1>

            <p class="lead text-light opacity-75 mx-auto" style="max-width: 800px;">
                A collection of projects that showcase my skills in .NET,
                ASP.NET Core, SQL Server, JavaScript, and software development.
            </p>
        </div>

        <!-- Projects -->
        <div class="row g-4">

            <!-- Employee Management System -->
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-lg h-100">

                    <div class="card-header bg-primary text-white py-4">
                        <h3 class="mb-0">Employee Management System</h3>
                    </div>

                    <div class="card-body d-flex flex-column">

                        <span class="badge bg-primary align-self-start mb-3">
                            ASP.NET Core MVC
                        </span>

                        <p class="text-muted">
                            A complete employee management application
                            built using ASP.NET Core MVC and Entity Framework Core.
                            The system allows administrators to manage employee
                            records efficiently.
                        </p>

                        <h6 class="fw-bold">Key Features</h6>

                        <ul class="text-muted">
                            <li>Employee CRUD Operations</li>
                            <li>Department Management</li>
                            <li>Search & Filtering</li>
                            <li>Data Validation</li>
                            <li>Responsive UI</li>
                            <li>SQL Server Integration</li>
                        </ul>

                        <h6 class="fw-bold mt-2">Tech Stack</h6>

                        <div class="mb-3">
                            <span class="badge bg-secondary">ASP.NET Core</span>
                            <span class="badge bg-secondary">C#</span>
                            <span class="badge bg-secondary">EF Core</span>
                            <span class="badge bg-secondary">SQL Server</span>
                            <span class="badge bg-secondary">Bootstrap</span>
                        </div>

                        @* <div class="mt-auto">
                            <button class="btn btn-primary me-2" disabled>
                                Live Demo Coming Soon
                            </button>

                            <button class="btn btn-outline-dark" disabled>
                                GitHub Coming Soon
                            </button>
                        </div> *@

                    </div>
                </div>
            </div>

            <!-- PGPulse -->
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-lg h-100">

                    <div class="card-header text-white py-4"
                         style="background-color:green;">
                        <h3 class="mb-0">PGPulse - Hostel Rating App</h3>
                    </div>

                    <div class="card-body d-flex flex-column">

                        <span class="badge bg-success align-self-start mb-3">
                            Full Stack Project
                        </span>

                        <p class="text-muted">
                            A PG and room rental management platform
                            that helps students and working professionals
                            find accommodations while enabling owners
                            to manage listings.
                        </p>

                        <h6 class="fw-bold">Key Features</h6>

                        <ul class="text-muted">
                            <li>User Registration & Login</li>
                            <li>Room Listings</li>
                            <li>Property Management</li>
                            <li>Image Upload</li>
                            <li>Search & Filters</li>
                            <li>Booking Information</li>
                        </ul>

                        <h6 class="fw-bold mt-2">Tech Stack</h6>

                        <div class="mb-3">
                            <span class="badge bg-secondary">ASP.NET Core</span>
                            <span class="badge bg-secondary">C#</span>
                            <span class="badge bg-secondary">SQL Server</span>
                            <span class="badge bg-secondary">Bootstrap</span>
                            <span class="badge bg-secondary">JavaScript</span>
                        </div>

                        @* <div class="mt-auto">
                            <button class="btn text-white me-2"
                                    style="background-color:green;"
                                    disabled>
                                Live Demo Coming Soon
                            </button>

                            <button class="btn border btn-outline-dark"
                                    disabled>
                                GitHub Coming Soon
                            </button>
                        </div> *@

                    </div>
                </div>
            </div>

            <!-- AutumnHQ -->
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-lg h-100">

                    <div class="card-header text-white py-4"
                         style="background-color:purple">
                        <h3 class="mb-0">AutumnHQ - VS Code Extension</h3>
                    </div>

                    <div class="card-body d-flex flex-column">

                        <span class="badge align-self-start mb-3"
                              style="background-color:purple">
                            VS Code Extension
                        </span>

                        <p class="text-muted">
                            A Visual Studio Code theme extension designed
                            to improve developer productivity by providing
                            useful dark pink & purple theme.
                        </p>

                        <h6 class="fw-bold">Key Features</h6>

                        <ul class="text-muted mt-4">
                            <li>Better User Experience</li>
                            <li>
                                Two Flavor
                                <ol>
                                    <li>Heartbeat</li>
                                    <li>Autumn</li>
                                </ol>
                            </li>
                            <li>Modern Extension For Eye Relax</li>
                            <li>Reduce The Eye Stress</li>
                        </ul>

                        <h6 class="fw-bold mt-2">Tech Stack</h6>

                        <div class="mb-3">
                            <span class="badge bg-secondary">JavaScript</span>
                            <span class="badge bg-secondary">JSON</span>
                        </div>

                        <div>

                        </div>
                        <div class="mt-auto d-flex justify-content-between">
                            <a href="https://marketplace.visualstudio.com/items?itemName=AutumnHQ.autumnhq"
                                class="btn me-2" target="_blank"
                                style="background-color:purple; color:white;"
                                disabled>
                                Marketplace
                            </a>

                            @* <button class="btn btn-outline-dark"
                                    disabled>
                                GitHub
                            </button> *@

                            <a href="https://autumnhq.vercel.app/"
                               target="_blank"
                               class="btn btn-warning">
                                Website
                            </a>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <!-- Project Stats -->
        <div class="row mt-5 g-4">

            <div class="col-md-4">
                <div class="card border-0 shadow text-center">
                    <div class="card-body py-4">
                        <h2 class="fw-bold text-primary">3+</h2>
                        <p class="text-muted mb-0">
                            Major Projects
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow text-center">
                    <div class="card-body py-4">
                        <h2 class="fw-bold" style="color:#800000;">
                            .NET
                        </h2>
                        <p class="text-muted mb-0">
                            Primary Technology
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow text-center">
                    <div class="card-body py-4">
                        <h2 class="fw-bold text-primary">
                            Full Stack
                        </h2>
                        <p class="text-muted mb-0">
                            Development Focus
                        </p>
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>
