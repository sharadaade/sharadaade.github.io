@page "/education"

<PageTitle>Education</PageTitle>

<section class="py-5 min-vh-100">
    <div class="container">

        <!-- Heading -->
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold text-danger">Education</h1>

            <p class="lead text-muted">
                My academic journey in Computer Applications.
            </p>
        </div>

        <!-- Education Cards -->
        <div class="row g-4">

            <!-- MCA -->
            <div class="col-lg-6">
                <div class="card border-0 shadow-lg h-100">

                    <div class="card-header text-white py-4" style="background-color:purple; color:white;">
                        <h2 class="mb-0">
                            Master of Computer Applications (MCA)
                        </h2>
                    </div>

                    <div class="card-body p-4">

                        <span class="badge mb-3" style="background-color:purple; color:white;">
                            Postgraduate Degree
                        </span>

                        <h4 class="fw-bold text-black">
                            Savitribai Phule Pune University (SPPU)
                        </h4>

                        <hr />

                        <div class="mb-3">
                            <h6 class="fw-bold text-black">
                                College Name
                            </h6>

                            <p class="text-muted">
                                Shri Swami Samarth Institutes, Malwadi (Bota)
                            </p>
                        </div>

                        <div class="mb-3">
                            <h6 class="fw-bold text-black">
                                Duration
                            </h6>

                            <p class="text-muted">
                                2024 - 2025
                            </p>
                        </div>

                        <div class="mb-3">
                            <h6 class="fw-bold text-black">
                                CGPA
                            </h6>

                            <p class="text-muted">
                                7.19
                            </p>
                        </div>

                    </div>
                </div>
            </div>

            <!-- BCA -->
            <div class="col-lg-6">
                <div class="card border-0 shadow-lg h-100">

                    <div class="card-header bg-success text-white py-4">
                        <h2 class="mb-0">
                            Bachelor of Computer Applications (BCA)
                        </h2>
                    </div>

                    <div class="card-body p-4">

                        <span class="badge bg-success mb-3">
                            Undergraduate Degree
                        </span>

                        <h4 class="fw-bold text-black">
                            Savitribai Phule Pune University (SPPU)
                        </h4>

                        <hr />

                        <div class="mb-3">
                            <h6 class="fw-bold text-black">
                                College Name
                            </h6>

                            <p class="text-muted">
                                New Arts, Commerce and Science College (Ahilyanagar)
                            </p>
                        </div>

                        <div class="mb-3">
                            <h6 class="fw-bold text-black">
                                Duration
                            </h6>

                            <p class="text-muted">
                                2021 - 2023
                            </p>
                        </div>

                        <div class="mb-3">
                            <h6 class="fw-bold text-black">
                                CGPA
                            </h6>

                            <p class="text-muted">
                                7.97
                            </p>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <!-- Summary -->
        <div class="row mt-5">

            <div class="col-12">

                <div class="card border-0 shadow">

                    <div class="card-body p-5 text-center">

                        <h3 class="fw-bold mb-3 text-black">
                            Academic Foundation
                        </h3>

                        <p class="text-muted mb-0">
                            Through my BCA and MCA studies at Savitribai Phule
                            Pune University, I developed strong knowledge in
                            software development, database management,
                            object-oriented programming, web technologies,
                            and modern application development.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>
</section>
