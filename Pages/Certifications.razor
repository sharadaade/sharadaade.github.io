@page "/certifications"

<PageTitle>Certifications</PageTitle>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold text-danger">My Certifications</h1>

        <p class="text-muted">
            Professional certifications and courses that have strengthened my technical skills.
        </p>
    </div>

    <div class="row g-4">

        <!-- Certification 1 -->
        <div class="col-lg-4 col-md-6">
            <div class="card shadow-sm border-0 h-100">

                <img src="certificates/c-sharp.png"
                     class="card-img-top"
                     alt=".NET Certification">

                <div class="card-body">

                    <h5 class="card-title fw-bold">
                        Foundational C# with Microsoft
                    </h5>

                    <p class="card-text text-muted">
                        Introduction to C#, control structures, and object-oriented programming principles.
                    </p>

                    <ul class="list-unstyled small text-black">
                        <li><strong>Issued By:</strong> freeCodeCamp & Microsoft</li>
                        <li><strong>Date:</strong> 2 November 2023</li>
                    </ul>

                </div>

                <div class="card-footer bg-white border-0">
                    <a href="https://www.freecodecamp.org/certification/sharadaade/foundational-c-sharp-with-microsoft"
                       target="_blank"
                       class="btn btn-primary w-100">
                        View Certificate
                    </a>
                </div>

            </div>
        </div>

        <!-- Certification 2 -->
        <div class="col-lg-4 col-md-6">
            <div class="card shadow-sm border-0 h-100">

                <img src="certificates/udemy-certificate.jpg"
                     class="card-img-top"
                     alt="ASP.NET Core MVC Certification">

                <div class="card-body">

                    <h5 class="card-title fw-bold">
                        ASP.NET Core MVC
                    </h5>

                    <p class="card-text text-muted">
                        Learned MVC architecture, ASP.NET Core Identity, Stripe payment integrations, and email notifications.
                    </p>

                    <ul class="list-unstyled small">
                        <li><strong>Issued By:</strong> Udemy</li>
                        <li><strong>Date:</strong> 31 May 2026</li>
                    </ul>

                </div>

                <div class="card-footer bg-white border-0">
                    <a href="https://www.udemy.com/certificate/UC-a828f7ca-e601-4982-ba8f-e3c1f82fce10/"
                       target="_blank"
                       class="btn btn-primary w-100">
                        View Certificate
                    </a>
                </div>

            </div>
        </div>

        <!-- Certification 3 -->
        <div class="col-lg-4 col-md-6">
            <div class="card shadow-sm border-0 h-100">

                <img src="certificates/programiz.png"
                     class="card-img-top"
                     alt="HTML Certification">

                <div class="card-body">

                    <h5 class="card-title fw-bold">
                        Learn HTML
                    </h5>

                    <p class="card-text text-muted">
                        Covered basics, forms, and semantic HTML concepts.
                    </p>

                    <ul class="list-unstyled small text-black">
                        <li><strong>Issued By:</strong> Programiz</li>
                        <li><strong>Date:</strong> 14 October 2025</li>
                    </ul>

                </div>

                <div class="card-footer bg-white border-0">
                    <a href="https://app.programiz.pro/certificates/detail/34A4F632AB84"
                       target="_blank"
                       class="btn btn-primary w-100">
                        View Certificate
                    </a>
                </div>

            </div>
        </div>

        <!-- Certification 4 -->
        <div class="col-lg-4 col-md-6">
            <div class="card shadow-sm border-0 h-100">

                <img src="certificates/nareshit-certificate.jpg"
                     class="card-img-top"
                     alt=".NET Full Stack Certification">

                <div class="card-body">

                    <h5 class="card-title fw-bold">
                        .NET Full Stack
                    </h5>

                    <p class="card-text text-muted">
                        Learned C#, MVC, ASP.NET Core, EF Core, MS SQL, and logic building.
                    </p>

                    <ul class="list-unstyled small">
                        <li><strong>Issued By:</strong> NareshIT</li>
                        <li><strong>Date:</strong> 31 April 2026</li>
                    </ul>

                </div>

                <div class="card-footer bg-white border-0">
                    <a href="certificates/nareshit-certificate.jpg" class="btn btn-primary w-100" target="_blank" role="button">
                        View Certificate
                    </a>
                </div>

            </div>
        </div>

    </div>
</div>
